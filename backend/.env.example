# Server
PORT=3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/contactvault

# Redis
REDIS_URI=redis://localhost:6379

# RabbitMQ
RABBITMQ_URI=amqp://localhost:5672

# API Key (the secret word users must send to obtain a JWT)
API_KEY=your-secret-key-here

# Logger (ON/OFF) - controls whether the log consumer is active
LOGGER=ON